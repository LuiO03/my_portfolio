---
import "../styles/components/navbar.css";
import { Icon } from "astro-icon/components";
const currentPath = Astro.url.pathname;
---

<nav class="navbar">
	<div class="navbar-content">
		<!-- div para implementar ancho maximo -->
		<a class="logo" href="/">LuiOsorio</a>
		<ul class="nav-links">
			<li>
				<a href="/" class={currentPath === "/" ? "active" : "disabled"}>
					<Icon class="nav-icon" name="tabler:home" />
					Inicio
				</a>
			</li>
			<li>
				<a href="/about" class={currentPath === "/about" ? "active" : "disabled"}>
					<Icon class="nav-icon" name="tabler:user" />
					Sobre mí
				</a>
			</li>
			<li>
				<a href="/projects" class={currentPath === "/projects" ? "active" : "disabled"}>
					<Icon class="nav-icon" name="tabler:briefcase" />
					Proyectos
				</a>
			</li>
			<li>
				<a href="/contact" class={currentPath === "/contact" ? "active" : "disabled"}>
					<Icon class="nav-icon" name="tabler:mail" />
					Contacto
				</a>
			</li>
			<li>
				<a href="/probar404" class={currentPath === "/probar404" ? "active" : "disabled"}>
					<Icon class="nav-icon" name="tabler:alert-circle" />
					Probar 404
				</a>
			</li>
		</ul>
		<div class="nav-overlay" aria-hidden="true"></div>
		<article class="nav-actions">
			<Icon id="theme-toggle" class="nav-icon-theme" name="tabler:moon-filled" />
			<button id="userSidebarToggle" class="nav-icon-hamburger" aria-label="Abrir menú de usuario">
				<span class="hamburger-line"></span>
				<span class="hamburger-line"></span>
				<span class="hamburger-line"></span>
			</button>
		</article>
	</div>
</nav>

<script>
	function initThemeToggle() {
		const btn = document.getElementById("theme-toggle");

		if (!btn) return;

		btn.onclick = () => {
			const dark = document.documentElement.classList.toggle("dark");

			localStorage.setItem("theme", dark ? "dark" : "light");
		};
	}

	function initMobileNavbarToggle() {
		const toggleBtn = document.getElementById("userSidebarToggle");
		const navLinks = document.querySelector(".nav-links");
		const navOverlay = document.querySelector(".nav-overlay");

		if (
			!(toggleBtn instanceof HTMLButtonElement) ||
			!(navLinks instanceof HTMLElement) ||
			!(navOverlay instanceof HTMLElement)
		)
			return;

		const isMobile = () => window.matchMedia("(max-width: 768px)").matches;
		const setExpanded = (isExpanded: boolean) => {
			toggleBtn.setAttribute("aria-expanded", String(isExpanded));
		};

		const closeMenu = () => {
			toggleBtn.classList.remove("active");
			navLinks.classList.remove("menu-open");
			navOverlay.classList.remove("visible");
			setExpanded(false);
		};

		const openMenu = () => {
			toggleBtn.classList.add("active");
			navLinks.classList.add("menu-open");
			navOverlay.classList.add("visible");
			setExpanded(true);
		};

		const syncByViewport = () => {
			if (!isMobile()) {
				navLinks.classList.remove("menu-open");
				navOverlay.classList.remove("visible");
				toggleBtn.classList.remove("active");
				setExpanded(false);
				return;
			}

			if (!navLinks.classList.contains("menu-open")) {
				closeMenu();
			}
		};

		if (toggleBtn.dataset.menuReady === "true") {
			syncByViewport();
			return;
		}

		toggleBtn.dataset.menuReady = "true";
		setExpanded(false);

		toggleBtn.onclick = () => {
			if (!isMobile()) return;

			if (navLinks.classList.contains("menu-open")) {
				closeMenu();
			} else {
				openMenu();
			}
		};

		navLinks.querySelectorAll("a").forEach((link) => {
			link.addEventListener("click", () => {
				if (isMobile()) closeMenu();
			});
		});

		navOverlay.addEventListener("click", () => {
			if (isMobile()) closeMenu();
		});

		window.addEventListener("resize", syncByViewport);
		syncByViewport();
	}

	initThemeToggle();
	initMobileNavbarToggle();
	document.addEventListener("astro:page-load", initThemeToggle);
	document.addEventListener("astro:page-load", initMobileNavbarToggle);
</script>

---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

interface Props {
	limit?: number;
}

const { limit } = Astro.props;

const projects = await getCollection("projects");

const visibleProjects = limit ? projects.slice(0, limit) : projects;

// Obtener todas las imágenes de proyectos
const allImages = import.meta.glob("/src/assets/projects/*/*.{jpg,jpeg,png,webp}", {
	eager: true,
	query: "?url",
	import: "default",
}) as Record<string, string>;

// Función para obtener la imagen principal del proyecto
function getProjectImage(projectId: string) {
	return Object.entries(allImages).find(([path]) => path.includes(`/projects/${projectId}/`))?.[1] ?? "";
}
---

<ul class="project-list">
	{
		visibleProjects.map((project) => {
			const projectImage = getProjectImage(project.id);

			return (
				<li class="project-item">
					<a class="project-image" href={`/projects/${project.id}/`}>
						<img src={projectImage} alt={project.data.title} transition:name={project.id} />
						<div class="project-overlay" />
					</a>
					<div class="project-info">
						<div class="project-details">
							<a transition:name={`${project.id}-title`} class="project-title" href={`/projects/${project.id}/`}>
								{project.data.title}
							</a>
							<div class="project-tags">
								{project.data.technologies?.map((tech) => (
									<div class="project-tag">
										<Icon name={tech.icon} class="tag-icon" />
										<span class="tag-name">{tech.name}</span>
									</div>
								))}
							</div>
							<p class="project-description">{project.data.short_description}</p>
						</div>
						<div class="project-links">
							{project.data.github && (
								<a href={project.data.github} target="_blank" rel="noopener noreferrer" class="button bg-dark">
									<Icon name="tabler:brand-github" class="button-icon" />
									GitHub
								</a>
							)}
							{project.data.demo && (
								<a href={project.data.demo} target="_blank" rel="noopener noreferrer" class="button bg-info">
									<Icon name="tabler:player-play" class="button-icon" />
									Demo
								</a>
							)}
							{project.data.figma && (
								<a href={project.data.figma} target="_blank" rel="noopener noreferrer" class="button bg-success">
									<Icon name="tabler:brand-figma" class="button-icon" />
									Figma
								</a>
							)}
						</div>

						<a class="project-arrow" href={`/projects/${project.id}/`}>
							<span class="project-arrow-text">Ver más detalles </span>
							<Icon name="tabler:arrow-right" class="project-arrow-icon" />
						</a>
					</div>
				</li>
			);
		})
	}
</ul>

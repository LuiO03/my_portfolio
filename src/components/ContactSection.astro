---
import { Icon } from "astro-icon/components";
import "../css/components/contact-section.css";
import Section from "./Section.astro";
import "../css/components/section.css";
import "../css/ui/form.css";
import "../css/ui/validation.css";
---

<Section id="contact">
	<div class="contact-container">
		<div class="contact-info">
			<div class="contact-content">
				<div class="contact-content-text">
					<h2>¿Tienes un proyecto en mente?</h2>
					<p>Estoy disponible para colaborar en proyectos web, desarrollo de sistemas, landing pages, tiendas virtuales y soluciones personalizadas.</p>
				</div>

				<div class="contact-image">
					<img src="/images/enviar-correo.png" alt="Luis Quispe Osorio" />
				</div>

				<div class="contact-cards">
					<div class="contact-card">
						<Icon name="tabler:mail" />
						<div>
							<h5>Email</h5>
							<span>antagonis.fenixand.7777@outlook.com</span>
						</div>
					</div>

					<div class="contact-card">
						<Icon name="tabler:phone" />
						<div>
							<h5>Teléfono</h5>
							<span>+51 922 616 232</span>
						</div>
					</div>

					<div class="contact-card">
						<Icon name="tabler:map-pin" />
						<div>
							<h5>Ubicación</h5>
							<span>Perú</span>
						</div>
					</div>
				</div>

				<div class="contact-socials">
					<a href="https://github.com/LuiO03" target="_blank">
						<Icon name="tabler:brand-github-filled" />
					</a>

					<a href="https://linkedin.com/in/luiO03" target="_blank">
						<Icon name="tabler:brand-linkedin-filled" />
					</a>

					<a href="https://facebook.com/luiO03" target="_blank">
						<Icon name="tabler:brand-facebook-filled" />
					</a>

					<a href="https://wa.me/51922616232" target="_blank">
						<Icon name="tabler:brand-whatsapp-filled" />
					</a>
				</div>
			</div>
		</div>

		<form class="form-contact" method="POST" enctype="multipart/form-data" id="contactForm">
			<div class="form-body">
				<div class="input-group">
					<label for="name" class="label-form">
						Nombre
						<i class="ri-asterisk text-accent"></i>
					</label>
					<div class="input-icon-container">
						<Icon name="tabler:user" class="input-icon" />
						<input type="text" name="name" id="name" class="input-form" placeholder="Ingrese el nombre" required data-validate="required|min:3|max:100|alphanumeric" />
					</div>
				</div>

				<div class="input-group">
					<label for="email" class="label-form">
						Correo electrónico
						<i class="ri-asterisk text-accent"></i>
					</label>
					<div class="input-icon-container">
						<Icon name="tabler:mail" class="input-icon" />
						<input type="email" name="email" id="email" class="input-form" required placeholder="usuario@ejemplo.com" data-validate="required|email" />
					</div>
				</div>

				<div class="input-group">
					<label for="company" class="label-form"> Empresa (Opcional) </label>
					<div class="input-icon-container">
						<Icon name="tabler:building" class="input-icon" />
						<input type="text" id="company" name="company" class="input-form" placeholder="Nombre de tu empresa" />
					</div>
				</div>

				<div class="input-group">
					<label for="subject" class="label-form">
						Asunto
						<i class="ri-asterisk text-accent"></i>
					</label>
					<div class="input-icon-container">
						<Icon name="tabler:user" class="input-icon" />
						<input type="text" name="subject" id="subject" class="input-form" placeholder="Ingrese el asunto" required data-validate="required|min:3|max:100|alphanumeric" />
					</div>
				</div>

				<div class="input-group">
					<label for="message" class="label-form">
						Mensaje
						<i class="ri-asterisk text-accent"></i>
					</label>
					<div class="input-icon-container">
						<textarea id="message" name="message" rows="6" class="input-form" placeholder="Cuéntame más sobre tu proyecto..." required data-validate="required|min:3|max:100"></textarea>
					</div>
				</div>
			</div>

			<button type="submit" class="button bg-accent" id="submitBtn">
				<Icon name="tabler:send" class="button-icon" />
				Enviar mensaje
			</button>
		</form>
	</div>
	<script>
		import "../js/contact-form.js";
	</script>
</Section>

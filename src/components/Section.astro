---
interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;

import "../styles/components/section.css";
---

<section class="section">
	<div class="section-header">
		<h2>{title}</h2>
		<p>{description}</p>
	</div>
    <div class="section-content">
        <slot />
    </div>
</section>
